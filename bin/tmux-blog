#!/usr/bin/env bash
set -euo pipefail

session="blog"
workdir="$HOME/Work/sudomarchy"

if tmux has-session -t "$session" 2>/dev/null; then
  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$session"
  else
    tmux attach-session -t "$session"
  fi
  exit 0
fi

tmux new-session -d -s "$session" -c "$workdir" -n opencode "opencode"
tmux new-window -t "$session" -c "$workdir" -n lazygit "lazygit"
tmux new-window -t "$session" -c "$workdir" -n server
tmux split-window -h -d -t "$session:server" -c "$workdir" "npm run dev"

tmux select-layout -t "$session:server" even-horizontal
tmux select-window -t "$session:opencode"

if [ -n "${TMUX:-}" ]; then
  tmux switch-client -t "$session"
else
  tmux attach-session -t "$session"
fi
