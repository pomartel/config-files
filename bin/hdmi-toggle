#!/usr/bin/env bash

LAPTOP="eDP-1"
HDMI="HDMI-A-1"
HDMI_RES="1920x1080@60"

hdmi_is_connected() {
    hyprctl -j monitors all | jq -e --arg output "$HDMI" \
        'any(.[]; .name == $output)' >/dev/null
}

hdmi_is_mirroring() {
    hyprctl -j monitors all | jq -e --arg output "$HDMI" \
        'any(.[]; .name == $output and .mirrorOf != null and .mirrorOf != "none")' >/dev/null
}

if hdmi_is_mirroring; then
    hyprctl eval "hl.monitor({ output = \"$HDMI\", disabled = true })"
    hyprctl eval "hl.monitor({ output = \"$LAPTOP\", mode = \"highrr\", position = \"auto\", scale = 2 })"
elif hdmi_is_connected; then
    hyprctl eval "hl.monitor({ output = \"$LAPTOP\", mode = \"$HDMI_RES\", position = \"auto\", scale = 2 })"
    hyprctl eval "hl.monitor({ output = \"$HDMI\", mode = \"preferred\", position = \"auto\", scale = \"auto\", mirror = \"$LAPTOP\" })"
else
    notify-send "No HDMI monitor detected"
fi
