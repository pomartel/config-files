#!/usr/bin/env bash
set -euo pipefail

device_name="${SPOTIFY_CONNECT_DEVICE:-Laptop}"
spotify_bin="/usr/bin/spotify"
oauth_file="${SPOTIFY_OAUTH_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/spotifyd/oauth.env}"

warn() {
  printf 'spotify: %s\n' "$*" >&2
}

transfer_to_device() {
  load_access_token

  if [[ -z "${SPOTIFY_ACCESS_TOKEN:-}" ]]; then
    warn "SPOTIFY_ACCESS_TOKEN is not set; opening Spotify without switching Connect output"
    return 0
  fi

  local devices_json device_id
  if ! devices_json=$(
    curl --fail --silent --show-error \
      --header "Authorization: Bearer $SPOTIFY_ACCESS_TOKEN" \
      https://api.spotify.com/v1/me/player/devices
  ); then
    warn "could not fetch Spotify Connect devices; opening Spotify without switching output"
    return 0
  fi

  device_id=$(
    jq -er --arg name "$device_name" \
      '.devices[] | select(.name == $name) | .id' <<<"$devices_json" |
      head -n 1
  ) || {
    warn "Spotify Connect device '$device_name' was not found; opening Spotify without switching output"
    return 0
  }

  if ! curl --fail --silent --show-error \
    --request PUT \
    --header "Authorization: Bearer $SPOTIFY_ACCESS_TOKEN" \
    --header "Content-Type: application/json" \
    --data "$(jq -cn --arg id "$device_id" '{device_ids: [$id], play: false}')" \
    https://api.spotify.com/v1/me/player >/dev/null; then
    warn "could not transfer Spotify playback to '$device_name'; opening Spotify anyway"
    return 0
  fi

  if ! curl --fail --silent --show-error \
    --request PUT \
    --header "Authorization: Bearer $SPOTIFY_ACCESS_TOKEN" \
    "https://api.spotify.com/v1/me/player/play?device_id=$device_id" >/dev/null; then
    warn "could not resume Spotify playback on '$device_name'; opening Spotify anyway"
  fi
}

load_access_token() {
  if [[ -n "${SPOTIFY_ACCESS_TOKEN:-}" ]]; then
    return 0
  fi

  if [[ -f "$oauth_file" ]]; then
    # shellcheck source=/home/po/.config/spotifyd/oauth.env
    source "$oauth_file"
  fi

  if [[ -z "${SPOTIFY_CLIENT_ID:-}" || -z "${SPOTIFY_REFRESH_TOKEN:-}" ]]; then
    return 0
  fi

  local response
  if ! response=$(
    curl --fail --silent --show-error \
      --request POST \
      --header "Content-Type: application/x-www-form-urlencoded" \
      --data-urlencode "client_id=$SPOTIFY_CLIENT_ID" \
      --data-urlencode "grant_type=refresh_token" \
      --data-urlencode "refresh_token=$SPOTIFY_REFRESH_TOKEN" \
      https://accounts.spotify.com/api/token
  ); then
    warn "could not refresh Spotify access token; run spotify-auth again"
    return 0
  fi

  SPOTIFY_ACCESS_TOKEN=$(jq -r '.access_token' <<<"$response")
  export SPOTIFY_ACCESS_TOKEN

  if jq -e '.refresh_token? // empty' <<<"$response" >/dev/null; then
    update_refresh_token "$(jq -r '.refresh_token' <<<"$response")"
  fi
}

update_refresh_token() {
  local refresh_token="$1"

  python3 - "$oauth_file" "$refresh_token" <<'PY'
import os
import stat
import sys

oauth_file, refresh_token = sys.argv[1:]

def shell_quote(value):
    return "'" + value.replace("'", "'\"'\"'") + "'"

try:
    with open(oauth_file) as file:
        lines = file.readlines()
except FileNotFoundError:
    lines = []

new_lines = []
seen = False
for line in lines:
    stripped = line.lstrip()
    if stripped.startswith("export SPOTIFY_REFRESH_TOKEN=") or stripped.startswith("SPOTIFY_REFRESH_TOKEN="):
        new_lines.append(f"export SPOTIFY_REFRESH_TOKEN={shell_quote(refresh_token)}\n")
        seen = True
    else:
        new_lines.append(line)

if not seen:
    if new_lines and new_lines[-1].strip():
        new_lines.append("\n")
    new_lines.append(f"export SPOTIFY_REFRESH_TOKEN={shell_quote(refresh_token)}\n")

os.makedirs(os.path.dirname(oauth_file), mode=0o700, exist_ok=True)
tmp_file = oauth_file + ".tmp"
with open(tmp_file, "w") as file:
    file.writelines(new_lines)
os.chmod(tmp_file, stat.S_IRUSR | stat.S_IWUSR)
os.replace(tmp_file, oauth_file)
PY
}

( transfer_to_device ) &
exec "$spotify_bin" "$@"
