#!/usr/bin/env bash
set -euo pipefail

if [[ -z "${CHROME_USER_DATA_DIR:-}" ]]; then
  export CHROME_USER_DATA_DIR="$HOME/.config/BraveSoftware/Brave-Origin-Beta"
fi

exec /opt/brave.com/brave-origin-beta/brave-origin \
  --ozone-platform=wayland \
  --ozone-platform-hint=wayland \
  --enable-features=TouchpadOverscrollHistoryNavigation \
  --load-extension="$HOME/.local/share/omarchy/default/chromium/extensions/copy-url" \
  "$@"
