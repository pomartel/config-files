#!/usr/bin/env bash
set -euo pipefail

# Lock the session unless connected to one of the "safe" Wi-Fi networks (SSIDs).

SAFE_SSIDS=("$@")

usage() {
  cat <<'EOF'
Usage:
  lock-unless-ssid SSID1 [SSID2 ...]
  Locks the current session unless the connected Wi-Fi SSID matches one of the provided SSIDs.
EOF
}

if ((${#SAFE_SSIDS[@]} == 0)); then
  usage >&2
  exit 2
fi

SSID=""
while read -r interface; do
  SSID="$(iw dev "$interface" link 2>/dev/null | sed -n 's/^[[:space:]]*SSID: //p')"
  [[ -n $SSID ]] && break
done < <(iw dev 2>/dev/null | sed -n 's/^[[:space:]]*Interface //p')

# Not connected to Wi-Fi => unsafe (lock).
if [[ -z "$SSID" ]]; then
  omarchy system lock
  exit 0
fi

# Exact match against allowlist
for safe in "${SAFE_SSIDS[@]}"; do
  if [[ "$SSID" == "$safe" ]]; then
    echo "On a safe network ($SSID). No need to lock."
    exit 0
  fi
done

omarchy system lock
