#!/bin/bash

set -u

special_workspace="${1:-}"

if [[ ! $special_workspace =~ ^[a-zA-Z0-9_-]+$ ]]; then
  echo "Usage: toggle-special-workspace <workspace-name>" >&2
  exit 2
fi

current_special_workspace=$(hyprctl monitors -j | jq -r '.[] | select(.focused) | .specialWorkspace.name')

hyprctl dispatch "hl.dsp.workspace.toggle_special(\"$special_workspace\")" >/dev/null

if [[ "$current_special_workspace" == "special:$special_workspace" ]]; then
  exit 1
fi

# Window rules are only applied when a window is opened. Recenter existing
# floating windows when moving a special workspace between monitors.
hyprctl clients -j |
  jq -r --arg workspace "special:$special_workspace" '.[] | select(.workspace.name == $workspace and .floating == true) | .address' |
  while read -r address; do
    hyprctl dispatch "hl.dsp.focus({ window = \"address:$address\" })" >/dev/null
    hyprctl dispatch 'hl.dsp.window.center({ preserve_reserved = true })' >/dev/null
  done
