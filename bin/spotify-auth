#!/usr/bin/env bash
set -euo pipefail

client_id="${SPOTIFY_CLIENT_ID:-c27ee3c9106747529838515691ed7da9}"
redirect_uri="${SPOTIFY_REDIRECT_URI:-http://127.0.0.1:8888/callback}"
scope="${SPOTIFY_SCOPE:-user-read-playback-state user-modify-playback-state}"
oauth_file="${SPOTIFY_OAUTH_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/spotifyd/oauth.env}"

python3 - "$client_id" "$redirect_uri" "$scope" "$oauth_file" <<'PY'
import base64
import hashlib
import http.server
import json
import os
import secrets
import stat
import sys
import urllib.parse
import urllib.request
import webbrowser

client_id, redirect_uri, scope, oauth_file = sys.argv[1:]
state = secrets.token_urlsafe(24)
code_verifier = secrets.token_urlsafe(64)
challenge = base64.urlsafe_b64encode(
    hashlib.sha256(code_verifier.encode()).digest()
).rstrip(b"=").decode()

callback = {}
redirect = urllib.parse.urlparse(redirect_uri)

class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        return

    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        params = urllib.parse.parse_qs(parsed.query)
        callback["code"] = params.get("code", [None])[0]
        callback["state"] = params.get("state", [None])[0]
        callback["error"] = params.get("error", [None])[0]
        self.send_response(200)
        self.send_header("Content-Type", "text/plain")
        self.end_headers()
        self.wfile.write(b"Spotify authorization received. You can close this tab.\n")

auth_url = "https://accounts.spotify.com/authorize?" + urllib.parse.urlencode({
    "response_type": "code",
    "client_id": client_id,
    "scope": scope,
    "redirect_uri": redirect_uri,
    "state": state,
    "code_challenge_method": "S256",
    "code_challenge": challenge,
})

print(auth_url)
webbrowser.open(auth_url)

with http.server.HTTPServer((redirect.hostname, redirect.port), Handler) as server:
    server.timeout = 300
    server.handle_request()

if callback.get("error"):
    raise SystemExit(f"Spotify authorization failed: {callback['error']}")
if callback.get("state") != state:
    raise SystemExit("Spotify authorization failed: state mismatch")
if not callback.get("code"):
    raise SystemExit("Spotify authorization failed: no authorization code received")

data = urllib.parse.urlencode({
    "client_id": client_id,
    "grant_type": "authorization_code",
    "code": callback["code"],
    "redirect_uri": redirect_uri,
    "code_verifier": code_verifier,
}).encode()

request = urllib.request.Request(
    "https://accounts.spotify.com/api/token",
    data=data,
    headers={"Content-Type": "application/x-www-form-urlencoded"},
)

try:
    with urllib.request.urlopen(request) as response:
        token = json.load(response)
except urllib.error.HTTPError as error:
    detail = error.read().decode()
    raise SystemExit(f"Spotify token request failed: {detail}")

def shell_quote(value):
    return "'" + value.replace("'", "'\"'\"'") + "'"

os.makedirs(os.path.dirname(oauth_file), mode=0o700, exist_ok=True)
try:
    with open(oauth_file) as file:
        lines = file.readlines()
except FileNotFoundError:
    lines = []

values = {
    "SPOTIFY_CLIENT_ID": client_id,
    "SPOTIFY_REFRESH_TOKEN": token["refresh_token"],
}
seen = set()
new_lines = []
for line in lines:
    stripped = line.lstrip()
    replaced = False
    for key, value in values.items():
        if stripped.startswith(f"export {key}=") or stripped.startswith(f"{key}="):
            new_lines.append(f"export {key}={shell_quote(value)}\n")
            seen.add(key)
            replaced = True
            break
    if not replaced:
        new_lines.append(line)

if new_lines and new_lines[-1].strip():
    new_lines.append("\n")
for key, value in values.items():
    if key not in seen:
        new_lines.append(f"export {key}={shell_quote(value)}\n")

tmp_file = oauth_file + ".tmp"
with open(tmp_file, "w") as file:
    file.writelines(new_lines)
os.chmod(tmp_file, stat.S_IRUSR | stat.S_IWUSR)
os.replace(tmp_file, oauth_file)
print(f"Saved Spotify refresh token to {oauth_file}")
PY
