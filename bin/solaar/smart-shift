#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/solaar-smart-shift"
TOKEN_FILE="$STATE_DIR/token"
FIRED_FILE="$STATE_DIR/fired"
HOLD_SECONDS="0.25"

mkdir -p "$STATE_DIR"

copy_selection() {
  wtype -M ctrl -k Insert -m ctrl
}

paste_clipboard() {
  wtype -M shift -k Insert -m shift
}

case "${1:-}" in
press)
  token="$(date +%s%N)"
  printf '%s\n' "$token" >"$TOKEN_FILE"
  rm -f "$FIRED_FILE"
  (
    sleep "$HOLD_SECONDS"
    if [[ -f "$TOKEN_FILE" ]] && [[ "$(cat "$TOKEN_FILE")" == "$token" ]]; then
      : >"$FIRED_FILE"
      paste_clipboard
    fi
  ) >/dev/null 2>&1 &
  ;;
release)
  if [[ -f "$TOKEN_FILE" ]]; then
    if [[ ! -f "$FIRED_FILE" ]]; then
      copy_selection
    fi
    rm -f "$TOKEN_FILE" "$FIRED_FILE"
  fi
  ;;
*)
  echo "usage: $0 press|release" >&2
  exit 2
  ;;
esac
