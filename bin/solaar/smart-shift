#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/solaar-smart-shift"
TOKEN_FILE="$STATE_DIR/token"
FIRED_FILE="$STATE_DIR/fired"
HOLD_SECONDS="0.2"

mkdir -p "$STATE_DIR"

in_ghostty() {
  [[ "$(hyprctl activewindow -j | jq -r '.class // ""')" == "com.mitchellh.ghostty" ]]
}

close_tab() {
  if in_ghostty; then
    wtype -M ctrl -M shift -k w -m shift -m ctrl
  else
    wtype -M ctrl -k w -m ctrl
  fi
}

open_tab() {
  if in_ghostty; then
    wtype -M ctrl -M shift -k t -m shift -m ctrl
  else
    wtype -M ctrl -k t -m ctrl
  fi
}

case "${1:-}" in
press)
  token="$(date +%s%N)"
  printf '%s\n' "$token" >"$TOKEN_FILE"
  rm -f "$FIRED_FILE"
  (
    sleep "$HOLD_SECONDS"
    if [[ -f "$TOKEN_FILE" ]] && [[ "$(cat "$TOKEN_FILE")" == "$token" ]]; then
      : >"$FIRED_FILE"
      open_tab
    fi
  ) >/dev/null 2>&1 &
  ;;
release)
  if [[ -f "$TOKEN_FILE" ]]; then
    if [[ ! -f "$FIRED_FILE" ]]; then
      close_tab
    fi
    rm -f "$TOKEN_FILE" "$FIRED_FILE"
  fi
  ;;
*)
  echo "usage: $0 press|release" >&2
  exit 2
  ;;
esac
