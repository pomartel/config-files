#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/solaar-middle-button"
TOKEN_FILE="$STATE_DIR/token"
HOLD_SECONDS="0.25"

mkdir -p "$STATE_DIR"

paste_clipboard() {
  wtype -M shift -k Insert -m shift
}

case "${1:-press}" in
press)
  token="$(date +%s%N)"
  printf '%s\n' "$token" >"$TOKEN_FILE"
  (
    sleep "$HOLD_SECONDS"
    if [[ -f "$TOKEN_FILE" ]] && [[ "$(cat "$TOKEN_FILE")" == "$token" ]]; then
      paste_clipboard
      rm -f "$TOKEN_FILE"
    fi
  ) >/dev/null 2>&1 &
  ;;
release)
  rm -f "$TOKEN_FILE"
  ;;
*)
  echo "usage: $0 press|release" >&2
  exit 2
  ;;
esac
