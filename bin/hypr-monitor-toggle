#!/usr/bin/env bash

ext="DP-1"

for w in {1..10}; do
  if hyprctl monitors | grep -q "^Monitor $ext"; then
    hyprctl keyword "workspace $w, gapsout:10, gapsin:5"
    [ $w -ne 6 ] && hyprctl dispatch moveworkspacetomonitor $w $ext
  else
    hyprctl keyword "workspace $w, gapsout:3, gapsin:1"
  fi
done

# Projector mode: if in mirror mode, set laptop monitor to 1080p60
if hyprctl monitors | grep -q "monitor mirrors"; then
  hyprctl keyword monitor "eDP-1,1920x1080@60,auto,2"
fi
