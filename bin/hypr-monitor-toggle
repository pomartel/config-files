#!/usr/bin/env bash

ext="DP-1"

monitor_is_active() {
  hyprctl -j monitors all | jq -e --arg output "$1" \
    'any(.[]; .name == $output and .disabled == false)' >/dev/null
}

mirror_is_active() {
  hyprctl -j monitors all | jq -e \
    'any(.[]; .mirrorOf != null and .mirrorOf != "none")' >/dev/null
}

workspace_exists() {
  hyprctl -j workspaces | jq -e --argjson workspace "$1" \
    'any(.[]; .id == $workspace)' >/dev/null
}

for w in {1..10}; do
  if monitor_is_active "$ext"; then
    hyprctl eval "hl.workspace_rule({ workspace = \"$w\", gaps_out = 10, gaps_in = 5 })"
    if [ "$w" -ne 6 ] && workspace_exists "$w"; then
      hyprctl eval "hl.dispatch(hl.dsp.workspace.move({ workspace = \"$w\", monitor = \"$ext\" }))"
    fi
  else
    hyprctl eval "hl.workspace_rule({ workspace = \"$w\", gaps_out = 3, gaps_in = 1 })"
  fi
done

# Projector mode: if in mirror mode, set laptop monitor to 1080p60
if mirror_is_active; then
  hyprctl eval 'hl.monitor({ output = "eDP-1", mode = "1920x1080@60", position = "auto", scale = 2 })'
else
  hyprctl eval 'hl.monitor({ output = "eDP-1", mode = "2880x1800@120", position = "auto", scale = 2 })'
fi
