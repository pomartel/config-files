#!/bin/bash

# Designed to be run by systemd timer every 30 seconds and switch power profile to power-saver when battery is low

TRIGGERED_FLAG="/run/user/$UID/omarchy_power_saver_profile_triggered"
BATTERY_THRESHOLD=60
BATTERY_LEVEL=$(omarchy-battery-remaining)
BATTERY_STATE=$(omarchy-battery-discharging)

if [[ -n $BATTERY_LEVEL && $BATTERY_LEVEL =~ ^[0-9]+$ ]]; then
  if [[ $BATTERY_STATE == "discharging" ]] && ((BATTERY_LEVEL <= BATTERY_THRESHOLD)); then
    if [[ ! -f $TRIGGERED_FLAG ]]; then
      powerprofilesctl set power-saver
      touch $TRIGGERED_FLAG
    fi
  else
    rm -f $TRIGGERED_FLAG
  fi
fi
