#!/bin/bash
COMPOSE_FILE="$HOME/.config/ubuntu-server-vm/docker-compose.yml"
CONTAINER_NAME="omarchy-ubuntu-server"
IMAGE_NAME="qemux/qemu"

check_prerequisites() {
  local disk_size_gb=${1:-32}
  local required_space=$((disk_size_gb + 6))  # Add overhead for Ubuntu Server ISO and temp files

  if [ ! -e /dev/kvm ]; then
    gum style \
      --border normal \
      --padding "1 2" \
      --margin "1" \
      "KVM virtualization not available!" \
      "" \
      "Please enable virtualization in BIOS or run:" \
      "  sudo modprobe kvm-intel  # for Intel CPUs" \
      "  sudo modprobe kvm-amd    # for AMD CPUs"
    exit 1
  fi

  local available_space
  available_space=$(df "$HOME" | awk 'NR==2 {print int($4/1024/1024)}')

  if [ "$available_space" -lt "$required_space" ]; then
    echo "Insufficient disk space!"
    echo "  Available: ${available_space}GB"
    echo "  Required: ${required_space}GB (${disk_size_gb}GB disk + 6GB overhead)"
    exit 1
  fi
}

wait_for_port() {
  local port="$1"
  local timeout="${2:-120}"
  local elapsed=0

  while ! nc -z 127.0.0.1 "$port" >/dev/null 2>&1; do
    sleep 2
    elapsed=$((elapsed + 2))
    if [ "$elapsed" -ge "$timeout" ]; then
      return 1
    fi
  done

  return 0
}

get_ssh_port() {
  local port
  port=$(grep -E '^[[:space:]]*-[[:space:]]*[0-9]+:22$' "$COMPOSE_FILE" | sed -E 's/.*- *([0-9]+):22/\1/' | head -n1)
  if [ -z "$port" ]; then
    port=2222
  fi
  echo "$port"
}

get_container_name() {
  local name
  name=$(grep -E '^[[:space:]]*container_name:[[:space:]]*' "$COMPOSE_FILE" | sed -E 's/.*container_name:[[:space:]]*//g' | head -n1 | tr -d '"')
  if [ -z "$name" ]; then
    name="$CONTAINER_NAME"
  fi
  echo "$name"
}

wait_for_ssh_ready() {
  local ssh_port="$1"
  local timeout="${2:-180}"
  local elapsed=0

  while [ "$elapsed" -lt "$timeout" ]; do
    local probe_output
    probe_output=$(ssh -o BatchMode=yes -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=2 -p "$ssh_port" no-such-user@127.0.0.1 true 2>&1 || true)

    if echo "$probe_output" | grep -Eq "Permission denied|publickey|password"; then
      return 0
    fi

    sleep 2
    elapsed=$((elapsed + 2))
  done

  return 1
}

install_ubuntu_server() {
  trap "echo ''; echo 'Installation cancelled by user'; exit 1" INT

  check_prerequisites

  omarchy-pkg-add gum openbsd-netcat

  mkdir -p "$HOME/.ubuntu-server"
  mkdir -p "$HOME/.config/ubuntu-server-vm"

  local total_ram
  local total_ram_gb
  local total_cores
  total_ram=$(free -h | awk 'NR==2 {print $2}')
  total_ram_gb=$(awk 'NR==1 {printf "%d", $2/1024/1024}' /proc/meminfo)
  total_cores=$(nproc)

  echo ""
  echo "System Resources Detected:"
  echo "  Total RAM: $total_ram"
  echo "  Total CPU Cores: $total_cores"
  echo ""

  local ram_options=""
  for size in 1 2 4 8 16 32 64; do
    if [ "$size" -le "$total_ram_gb" ]; then
      ram_options="$ram_options ${size}G"
    fi
  done

  local selected_ram
  selected_ram=$(echo "$ram_options" | tr ' ' '\n' | sed '/^$/d' | gum choose --selected="2G" --header="How much RAM would you like to allocate to Ubuntu Server VM?")
  if [ -z "$selected_ram" ]; then
    echo "Installation cancelled by user"
    exit 1
  fi

  local selected_cores
  selected_cores=$(gum input --placeholder="Number of CPU cores (1-$total_cores)" --value="2" --header="How many CPU cores would you like to allocate?" --char-limit=2)
  if [ -z "$selected_cores" ]; then
    echo "Installation cancelled by user"
    exit 1
  fi

  if ! [[ "$selected_cores" =~ ^[0-9]+$ ]] || [ "$selected_cores" -lt 1 ] || [ "$selected_cores" -gt "$total_cores" ]; then
    echo "Invalid input. Using default: 2 cores"
    selected_cores=2
  fi

  local available_space
  available_space=$(df "$HOME" | awk 'NR==2 {print int($4/1024/1024)}')
  local max_disk_gb=$((available_space - 6))

  if [ "$max_disk_gb" -lt 16 ]; then
    echo "Insufficient disk space for Ubuntu Server VM!"
    echo "  Available: ${available_space}GB"
    echo "  Minimum required: 22GB (16GB disk + 6GB overhead)"
    exit 1
  fi

  local disk_options=""
  for size in 16 32 64 128 256 512; do
    if [ "$size" -le "$max_disk_gb" ]; then
      disk_options="$disk_options ${size}G"
    fi
  done

  local default_disk="32G"
  if ! echo "$disk_options" | grep -q "32G"; then
    default_disk="16G"
  fi

  local selected_disk
  selected_disk=$(echo "$disk_options" | tr ' ' '\n' | sed '/^$/d' | gum choose --selected="$default_disk" --header="How much disk space would you like to give Ubuntu Server VM?")
  if [ -z "$selected_disk" ]; then
    echo "Installation cancelled by user"
    exit 1
  fi

  local ssh_port
  ssh_port=$(gum input --placeholder="Host SSH port (1024-65535)" --value="2222" --header="Choose a host port to forward to VM SSH (port 22):" --char-limit=5)
  if [ -z "$ssh_port" ]; then
    echo "Installation cancelled by user"
    exit 1
  fi

  if ! [[ "$ssh_port" =~ ^[0-9]+$ ]] || [ "$ssh_port" -lt 1024 ] || [ "$ssh_port" -gt 65535 ]; then
    echo "Invalid input. Using default SSH port: 2222"
    ssh_port=2222
  fi

  local disk_size_num
  disk_size_num=$(echo "$selected_disk" | sed 's/G//')
  check_prerequisites "$disk_size_num"

  gum style \
    --border normal \
    --padding "1 2" \
    --margin "1" \
    --align left \
    --bold \
    "Ubuntu Server VM Configuration" \
    "" \
    "RAM:        $selected_ram" \
    "CPU:        $selected_cores cores" \
    "Disk:       $selected_disk" \
    "SSH Port:   $ssh_port -> 22"

  echo ""
  if ! gum confirm "Proceed with this configuration?"; then
    echo "Installation cancelled by user"
    exit 1
  fi

  cat << EOF_COMPOSE | tee "$COMPOSE_FILE" > /dev/null
services:
  ubuntu-server:
    image: $IMAGE_NAME
    container_name: $CONTAINER_NAME
    environment:
      BOOT: "ubuntus"
      RAM_SIZE: "$selected_ram"
      CPU_CORES: "$selected_cores"
      DISK_SIZE: "$selected_disk"
    devices:
      - /dev/kvm
      - /dev/net/tun
    cap_add:
      - NET_ADMIN
    ports:
      - 8006:8006
      - ${ssh_port}:22
    volumes:
      - $HOME/.ubuntu-server:/storage
    restart: "no"
    stop_grace_period: 2m
EOF_COMPOSE

  echo ""
  echo "Starting Ubuntu Server VM installation..."
  echo "This will download the Ubuntu Server image (may take several minutes)."
  echo ""

  if ! docker-compose -f "$COMPOSE_FILE" up -d >/dev/null 2>&1; then
    echo "Failed to start Ubuntu Server VM!"
    echo "  Common issues:"
    echo "  - Docker daemon not running: sudo systemctl start docker"
    echo "  - Ports already in use (8006 or $ssh_port)"
    echo "  - Permission issues: make sure you're in the docker group"
    exit 1
  fi

  echo "Ubuntu Server VM is starting up."
  echo "Web console: http://127.0.0.1:8006"
  echo "SSH tunnel:  ssh -p $ssh_port <user>@127.0.0.1"
  echo ""
  echo "Installation runs in the background."
  echo "Complete Ubuntu Server install in the web console, then connect via SSH."
  echo "To stop the VM: ubuntu-server-vm stop"
}

remove_ubuntu_server() {
  echo "Removing Ubuntu Server VM..."

  docker-compose -f "$COMPOSE_FILE" down 2>/dev/null || true
  docker rmi "$IMAGE_NAME" 2>/dev/null || echo "Image already removed or not found"

  rm -f "$HOME/.local/share/applications/ubuntu-server-vm.desktop"
  rm -f "$HOME/.local/share/applications/ubuntu-vm.desktop"
  rm -rf "$HOME/.config/ubuntu-server-vm"
  rm -rf "$HOME/.ubuntu-server"

  echo ""
  echo "Ubuntu Server VM removal completed!"
}

launch_ubuntu_server() {
  if [ ! -f "$COMPOSE_FILE" ]; then
    echo "Ubuntu Server VM not configured. Please run: ubuntu-server-vm install"
    exit 1
  fi

  local ssh_port
  ssh_port=$(get_ssh_port)

  local container_status
  container_status=$(docker inspect --format='{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null)

  if [ "$container_status" != "running" ]; then
    echo "Starting Ubuntu Server VM..."
    notify-send "Ubuntu Server VM" "Starting VM (15-30 seconds)" -t 15000

    if ! docker-compose -f "$COMPOSE_FILE" up -d >/dev/null 2>&1; then
      echo "Failed to start Ubuntu Server VM!"
      echo "  Try checking: ubuntu-server-vm status"
      echo "  View logs: docker logs $CONTAINER_NAME"
      notify-send -u critical "Ubuntu Server VM" "Failed to start VM"
      exit 1
    fi
  fi

  if ! wait_for_port 8006 120; then
    echo "Timed out waiting for web console on port 8006"
    exit 1
  fi

  gum style \
    --border normal \
    --padding "1 2" \
    --margin "1" \
    --align center \
    "Ubuntu Server VM Running" \
    "" \
    "Web console: http://127.0.0.1:8006" \
    "SSH:         ssh -p $ssh_port <user>@127.0.0.1"
}

ssh_ubuntu_server() {
  if [ ! -f "$COMPOSE_FILE" ]; then
    echo "Ubuntu Server VM not configured. Please run: ubuntu-server-vm install"
    exit 1
  fi

  local resolved_container_name
  resolved_container_name=$(get_container_name)

  local container_status
  container_status=$(docker inspect --format='{{.State.Status}}' "$resolved_container_name" 2>/dev/null)

  if [ "$container_status" != "running" ]; then
    echo "Starting Ubuntu Server VM..."
    notify-send "Ubuntu Server VM" "Starting VM (15-30 seconds)" -t 15000

    if ! docker-compose -f "$COMPOSE_FILE" up -d >/dev/null 2>&1; then
      echo "Failed to start Ubuntu Server VM!"
      echo "  Try checking: ubuntu-server-vm status"
      echo "  View logs: docker logs $CONTAINER_NAME"
      notify-send -u critical "Ubuntu Server VM" "Failed to start VM"
      exit 1
    fi
  fi

  local ssh_port
  ssh_port=$(get_ssh_port)

  if ! wait_for_ssh_ready "$ssh_port" 180; then
    echo "SSH service in VM did not become ready on port $ssh_port within timeout."
    echo "  Check VM console: http://127.0.0.1:8006"
    echo "  Check logs: docker logs $resolved_container_name"
    exit 1
  fi

  local ssh_user
  ssh_user="${2:-po}"

  local ssh_term
  ssh_term="${OMARCHY_VM_SSH_TERM:-xterm-256color}"

  echo "Connecting over SSH on port $ssh_port as user '$ssh_user'..."
  echo "Disconnect to stop the VM."
  TERM="$ssh_term" ssh -p "$ssh_port" "$ssh_user"@127.0.0.1

  echo ""
  echo "SSH disconnected. Stopping Ubuntu Server VM..."
  docker-compose -f "$COMPOSE_FILE" down
  echo "Ubuntu Server VM stopped."
}

stop_ubuntu_server() {
  if [ ! -f "$COMPOSE_FILE" ]; then
    echo "Ubuntu Server VM not configured."
    exit 1
  fi

  echo "Stopping Ubuntu Server VM..."
  docker-compose -f "$COMPOSE_FILE" down
  echo "Ubuntu Server VM stopped."
}

status_ubuntu_server() {
  if [ ! -f "$COMPOSE_FILE" ]; then
    echo "Ubuntu Server VM not configured."
    echo "To set up: ubuntu-server-vm install"
    exit 1
  fi

  local resolved_container_name
  resolved_container_name=$(get_container_name)

  local ssh_port
  ssh_port=$(get_ssh_port)

  local container_status
  container_status=$(docker inspect --format='{{.State.Status}}' "$resolved_container_name" 2>/dev/null)

  if [ -z "$container_status" ]; then
    echo "Ubuntu Server VM container not found."
    echo "To start: ubuntu-server-vm launch"
  elif [ "$container_status" = "running" ]; then
    gum style \
      --border normal \
      --padding "1 2" \
      --margin "1" \
      --align left \
      "Ubuntu Server VM Status: RUNNING" \
      "" \
      "Web console: http://127.0.0.1:8006" \
      "SSH:         ssh -p $ssh_port <user>@127.0.0.1" \
      "" \
      "To open console: ubuntu-server-vm launch" \
      "To stop:         ubuntu-server-vm stop"
  else
    echo "Ubuntu Server VM is stopped (status: $container_status)"
    echo "To start: ubuntu-server-vm launch"
  fi
}

show_usage() {
  echo "Usage: ubuntu-server-vm [command]"
  echo ""
  echo "Commands:"
  echo "  install              Install and configure Ubuntu VM"
  echo "  remove               Remove Ubuntu VM and its local config"
  echo "  launch|start         Start VM (if needed)"
  echo "  ssh [user]           SSH into the VM (default user: po)"
  echo "  stop|down            Stop the running VM"
  echo "  status               Show current VM status"
  echo "  help                 Show this help message"
  echo ""
  echo "Examples:"
  echo "  ubuntu-server-vm install"
  echo "  ubuntu-server-vm launch"
  echo "  ubuntu-server-vm ssh po"
  echo "  ubuntu-server-vm stop"
}

case "$1" in
  install)
    install_ubuntu_server
    ;;
  remove)
    remove_ubuntu_server
    ;;
  launch|start)
    launch_ubuntu_server
    ;;
  ssh)
    ssh_ubuntu_server "$@"
    ;;
  stop|down)
    stop_ubuntu_server
    ;;
  status)
    status_ubuntu_server
    ;;
  help|--help|-h|"")
    show_usage
    ;;
  *)
    echo "Unknown command: $1" >&2
    echo "" >&2
    show_usage >&2
    exit 1
    ;;
esac
