#!/bin/bash
COMPOSE_FILE="$HOME/.config/omarchy-vm/docker-compose.yml"
CONTAINER_NAME="omarchy-vm"
IMAGE_NAME="qemux/qemu"

check_prerequisites() {
  local disk_size_gb=${1:-32}
  local required_space=$((disk_size_gb + 8)) # Add overhead for Omarchy ISO and temp files

  if [ ! -e /dev/kvm ]; then
    gum style \
      --border normal \
      --padding "1 2" \
      --margin "1" \
      "KVM virtualization not available!" \
      "" \
      "Please enable virtualization in BIOS or run:" \
      "  sudo modprobe kvm-intel  # for Intel CPUs" \
      "  sudo modprobe kvm-amd    # for AMD CPUs"
    exit 1
  fi

  local available_space
  available_space=$(df "$HOME" | awk 'NR==2 {print int($4/1024/1024)}')

  if [ "$available_space" -lt "$required_space" ]; then
    echo "Insufficient disk space!"
    echo "  Available: ${available_space}GB"
    echo "  Required: ${required_space}GB (${disk_size_gb}GB disk + 6GB overhead)"
    exit 1
  fi
}

wait_for_port() {
  local port="$1"
  local timeout="${2:-120}"
  local elapsed=0

  while ! nc -z 127.0.0.1 "$port" >/dev/null 2>&1; do
    sleep 2
    elapsed=$((elapsed + 2))
    if [ "$elapsed" -ge "$timeout" ]; then
      return 1
    fi
  done

  return 0
}

get_latest_omarchy_iso_url() {
  local iso_url
  local latest_version

  latest_version=$(curl -fsSL -H "Accept: application/vnd.github+json" \
    -H "User-Agent: omarchy-vm" \
    https://api.github.com/repos/basecamp/omarchy/releases/latest |
    sed -nE 's/.*"tag_name":[[:space:]]*"v?([0-9.]+)".*/\1/p' |
    head -n1)

  if [ -z "$latest_version" ]; then
    latest_version=$(curl -fsSL -H "User-Agent: omarchy-vm" https://github.com/basecamp/omarchy/releases |
      grep -Eo 'tag/v[0-9.]+\"' |
      sed -E 's#tag/v([0-9.]+)".*#\1#' |
      sort -V |
      tail -n1)
  fi

  if [ -z "$latest_version" ]; then
    echo "Failed to determine the latest Omarchy ISO URL." >&2
    return 1
  fi

  iso_url="https://iso.omarchy.org/omarchy-${latest_version}.iso"
  echo "$iso_url"
}

install_omarchy_vm() {
  trap "echo ''; echo 'Installation cancelled by user'; exit 1" INT

  check_prerequisites

  omarchy-pkg-add gum openbsd-netcat curl

  mkdir -p "$HOME/.omarchy-vm"
  mkdir -p "$HOME/.config/omarchy-vm"

  cat <<EOF_DESKTOP | tee "$HOME/.local/share/applications/omarchy-vm.desktop" >/dev/null
[Desktop Entry]
Name=Omarchy VM
Comment=Start Omarchy VM and open web console
Exec=uwsm app -- omarchy-vm launch
Icon=${OMARCHY_PATH}icon.png
Terminal=false
Type=Application
Categories=System;Virtualization;
EOF_DESKTOP

  local total_ram
  local total_ram_gb
  local total_cores
  total_ram=$(free -h | awk 'NR==2 {print $2}')
  total_ram_gb=$(awk 'NR==1 {printf "%d", $2/1024/1024}' /proc/meminfo)
  total_cores=$(nproc)

  echo ""
  echo "System Resources Detected:"
  echo "  Total RAM: $total_ram"
  echo "  Total CPU Cores: $total_cores"
  echo ""

  local ram_options=""
  for size in 1 2 4 8 16 32 64; do
    if [ "$size" -le "$total_ram_gb" ]; then
      ram_options="$ram_options ${size}G"
    fi
  done

  local selected_ram
  selected_ram=$(echo "$ram_options" | tr ' ' '\n' | sed '/^$/d' | gum choose --selected="8G" --header="How much RAM would you like to allocate to Omarchy VM?")
  if [ -z "$selected_ram" ]; then
    echo "Installation cancelled by user"
    exit 1
  fi

  local selected_cores
  selected_cores=$(gum input --placeholder="Number of CPU cores (1-$total_cores)" --value="2" --header="How many CPU cores would you like to allocate?" --char-limit=2)
  if [ -z "$selected_cores" ]; then
    echo "Installation cancelled by user"
    exit 1
  fi

  if ! [[ "$selected_cores" =~ ^[0-9]+$ ]] || [ "$selected_cores" -lt 1 ] || [ "$selected_cores" -gt "$total_cores" ]; then
    echo "Invalid input. Using default: 2 cores"
    selected_cores=2
  fi

  local available_space
  available_space=$(df "$HOME" | awk 'NR==2 {print int($4/1024/1024)}')
  local max_disk_gb=$((available_space - 8))

  if [ "$max_disk_gb" -lt 16 ]; then
    echo "Insufficient disk space for Omarchy VM!"
    echo "  Available: ${available_space}GB"
    echo "  Minimum required: 24GB (16GB disk + 8GB overhead)"
    exit 1
  fi

  local disk_options=""
  for size in 16 32 64 128 256 512; do
    if [ "$size" -le "$max_disk_gb" ]; then
      disk_options="$disk_options ${size}G"
    fi
  done

  local default_disk="32G"
  if ! echo "$disk_options" | grep -q "32G"; then
    default_disk="16G"
  fi

  local selected_disk
  selected_disk=$(echo "$disk_options" | tr ' ' '\n' | sed '/^$/d' | gum choose --selected="$default_disk" --header="How much disk space would you like to give Omarchy VM?")
  if [ -z "$selected_disk" ]; then
    echo "Installation cancelled by user"
    exit 1
  fi

  local disk_size_num
  disk_size_num=$(echo "$selected_disk" | sed 's/G//')
  check_prerequisites "$disk_size_num"

  local omarchy_iso_url
  omarchy_iso_url=$(get_latest_omarchy_iso_url) || exit 1

  gum style \
    --border normal \
    --padding "1 2" \
    --margin "1" \
    --align left \
    --bold \
    "Omarchy VM Configuration" \
    "" \
    "RAM:        $selected_ram" \
    "CPU:        $selected_cores cores" \
    "Disk:       $selected_disk" \
    "" \
    "ISO:        $omarchy_iso_url"

  echo ""
  if ! gum confirm "Proceed with this configuration?"; then
    echo "Installation cancelled by user"
    exit 1
  fi

  cat <<EOF_COMPOSE | tee "$COMPOSE_FILE" >/dev/null
services:
  omarchy:
    image: $IMAGE_NAME
    container_name: $CONTAINER_NAME
    environment:
      BOOT: "$omarchy_iso_url"
      BOOT_MODE: "legacy"
      RAM_SIZE: "$selected_ram"
      CPU_CORES: "$selected_cores"
      DISK_SIZE: "$selected_disk"
      ARGUMENTS: "-action shutdown=poweroff"
    devices:
      - /dev/kvm
      - /dev/net/tun
    cap_add:
      - NET_ADMIN
    ports:
      - 8006:8006
    volumes:
      - $HOME/.omarchy-vm:/storage
    restart: "no"
    stop_grace_period: 2m
EOF_COMPOSE

  echo ""
  echo "Starting Omarchy VM installation..."
  echo "This will download the Omarchy Linux ISO (may take several minutes)."
  echo ""

  if ! docker-compose -f "$COMPOSE_FILE" up -d >/dev/null 2>&1; then
    echo "Failed to start Omarchy VM!"
    echo "  Common issues:"
    echo "  - Docker daemon not running: sudo systemctl start docker"
    echo "  - Port 8006 already in use"
    echo "  - Permission issues: make sure you're in the docker group"
    exit 1
  fi

  echo "Omarchy VM is starting up."
  echo "Web console: http://127.0.0.1:8006"
  echo ""
  echo "Opening web console..."
  sleep 3
  setsid omarchy-launch-webapp "http://127.0.0.1:8006" >/dev/null 2>&1 &

  echo ""
  echo "Installation runs in the background."
  echo "Complete the Omarchy install in the web console."
  echo "To stop the VM: omarchy-vm stop"
}

remove_omarchy_vm() {
  echo "Removing Omarchy VM..."

  docker-compose -f "$COMPOSE_FILE" down 2>/dev/null || true
  docker rmi "$IMAGE_NAME" 2>/dev/null || echo "Image already removed or not found"

  rm -f "$HOME/.local/share/applications/omarchy-vm.desktop"
  rm -rf "$HOME/.config/omarchy-vm"
  rm -rf "$HOME/.omarchy-vm"

  echo ""
  echo "Omarchy VM removal completed!"
}

launch_omarchy_vm() {
  if [ ! -f "$COMPOSE_FILE" ]; then
    echo "Omarchy VM not configured. Please run: omarchy-vm install"
    exit 1
  fi

  local container_status
  container_status=$(docker inspect --format='{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null)

  if [ "$container_status" != "running" ]; then
    echo "Starting Omarchy VM..."
    notify-send "Omarchy VM" "Starting VM (15-30 seconds)" -t 15000

    if ! docker-compose -f "$COMPOSE_FILE" up -d >/dev/null 2>&1; then
      echo "Failed to start Omarchy VM!"
      echo "  Try checking: omarchy-vm status"
      echo "  View logs: docker logs $CONTAINER_NAME"
      notify-send -u critical "Omarchy VM" "Failed to start VM"
      exit 1
    fi
  fi

  if ! wait_for_port 8006 120; then
    echo "Timed out waiting for web console on port 8006"
    exit 1
  fi

  gum style \
    --border normal \
    --padding "1 2" \
    --margin "1" \
    --align center \
    "Omarchy VM Running" \
    "" \
    "Web console: http://127.0.0.1:8006"

  setsid omarchy-launch-webapp "http://127.0.0.1:8006" >/dev/null 2>&1 &
  disown
}

stop_omarchy_vm() {
  if [ ! -f "$COMPOSE_FILE" ]; then
    echo "Omarchy VM not configured."
    exit 1
  fi

  echo "Stopping Omarchy VM..."
  docker-compose -f "$COMPOSE_FILE" down
  echo "Omarchy VM stopped."
}

status_omarchy_vm() {
  if [ ! -f "$COMPOSE_FILE" ]; then
    echo "Omarchy VM not configured."
    echo "To set up: omarchy-vm install"
    exit 1
  fi

  local container_status
  container_status=$(docker inspect --format='{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null)

  if [ -z "$container_status" ]; then
    echo "Omarchy VM container not found."
    echo "To start: omarchy-vm launch"
  elif [ "$container_status" = "running" ]; then
    gum style \
      --border normal \
      --padding "1 2" \
      --margin "1" \
      --align left \
      "Omarchy VM Status: RUNNING" \
      "" \
      "Web console: http://127.0.0.1:8006" \
      "To open console: omarchy-vm launch" \
      "To stop:         omarchy-vm stop"
  else
    echo "Omarchy VM is stopped (status: $container_status)"
    echo "To start: omarchy-vm launch"
  fi
}

show_usage() {
  echo "Usage: omarchy-vm [command]"
  echo ""
  echo "Commands:"
  echo "  install              Install and configure Omarchy VM"
  echo "  remove               Remove Omarchy VM and its local config"
  echo "  launch|start         Start VM (if needed) and open web console"
  echo "  stop|down            Stop the running VM"
  echo "  status               Show current VM status"
  echo "  help                 Show this help message"
  echo ""
  echo "Examples:"
  echo "  omarchy-vm install"
  echo "  omarchy-vm launch"
  echo "  omarchy-vm stop"
}

case "$1" in
install)
  install_omarchy_vm
  ;;
remove)
  remove_omarchy_vm
  ;;
launch | start)
  launch_omarchy_vm
  ;;
stop | down)
  stop_omarchy_vm
  ;;
status)
  status_omarchy_vm
  ;;
help | --help | -h | "")
  show_usage
  ;;
*)
  echo "Unknown command: $1" >&2
  echo "" >&2
  show_usage >&2
  exit 1
  ;;
esac
