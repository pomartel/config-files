#!/bin/bash

# If any Mains/USB source is online, assume AC.
for power_supply in /sys/class/power_supply/*; do
  type=$(cat "$power_supply/type" 2>/dev/null)
  if [[ "$type" = "Mains" || "$type" = "USB" ]]; then
    [[ "$(cat "$power_supply/online" 2>/dev/null)" = "1" ]] && exit 1
  fi
done

# Otherwise treat as battery.
exit 0
