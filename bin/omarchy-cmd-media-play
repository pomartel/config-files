#!/bin/bash

# Toggle the active player when one is available. Otherwise open Spotify and resume playback.

if playerctl status >/dev/null 2>&1; then
  exec omarchy-swayosd-client --playerctl play-pause
fi

spotify_address=$(hyprctl clients -j | jq -r '.[] | select((.class | ascii_downcase) == "spotify") | .address' | head -n1)

if [[ -n $spotify_address ]]; then
  hyprctl dispatch focuswindow "address:$spotify_address" >/dev/null 2>&1
else
  hyprctl dispatch exec "[workspace 6 silent] uwsm-app -- spotify" >/dev/null 2>&1
fi

sleep 1
exec playerctl --player=spotify play
