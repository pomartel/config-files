#!/bin/bash

# Usage: omarchy-powerprofiles-set <ac|battery>

case "$1" in
ac)
  powerprofilesctl set balanced
  if [ "$(hostname)" = "home-omarchy" ]; then
    echo balance_power | sudo tee /sys/devices/system/cpu/cpu*/cpufreq/energy_performance_preference
  fi
  ;;
battery)
  powerprofilesctl set balanced
  ;;
esac
