#!/bin/bash

# Designed to be run by systemd timer every minute and switch power profile to power-saver mode when battery is low

NOTIFICATION_FLAG="/run/user/$UID/omarchy_power_profile_notified"
BATTERY_THRESHOLD=60
POWER_PROFILE="power-saver"
BATTERY_LEVEL=$(omarchy-battery-remaining)
BATTERY_STATE=$(upower -i $(upower -e | grep 'BAT') | grep -E "state" | awk '{print $2}')

send_notification() {
  notify-send -u critical "󱐋 Switching to $POWER_PROFILE mode!" "Battery is down to ${1}%" -i battery-caution -t 5000
}

if [[ -n $BATTERY_LEVEL && $BATTERY_LEVEL =~ ^[0-9]+$ ]]; then
  if [[ $BATTERY_STATE == "discharging" ]] && ((BATTERY_LEVEL <= BATTERY_THRESHOLD)); then
    if [[ ! -f $NOTIFICATION_FLAG ]]; then
      send_notification $BATTERY_LEVEL
      powerprofilesctl set $POWER_PROFILE
      touch $NOTIFICATION_FLAG
    fi
  else
    rm -f $NOTIFICATION_FLAG
  fi
fi
