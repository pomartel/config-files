# Changes require a restart to take effect.
#

# Ensure Omarchy bins are in the path
if [ -d "$HOME/Work/omarchy" ]; then
  export OMARCHY_PATH="$HOME/Work/omarchy"
fi

export POWER_SAVER_BATTERY_TRESHOLD=70

export PATH=$OMARCHY_PATH/bin:$PATH

# Add user scripts to PATH
export PATH=$HOME/bin:$PATH

# Set default terminal and editor
source ~/.config/uwsm/default

# Set API keys and other sensitive data
source ~/.config/uwsm/secrets

# Activate mise if present on the system
omarchy-cmd-present mise && eval "$(mise activate bash)"
