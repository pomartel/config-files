// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Pane",
    "bindings": {
      "ctrl-shift-tab": "pane::ActivatePreviousItem",
      "ctrl-tab": "pane::ActivateNextItem",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
      "ctrl-shift-alt-r": "task::Spawn",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "bindings": {
      "ctrl-alt-t": "terminal_panel::ToggleFocus",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-shift-t": "workspace::NewTerminal",
    },
  },
  {
    "bindings": {
      "ctrl-alt-up": "workspace::ActivatePaneUp",
    },
  },
  {
    "bindings": {
      "ctrl-alt-down": "workspace::ActivatePaneDown",
    },
  },
  {
    "bindings": {
      "ctrl-alt-left": "workspace::ActivatePaneLeft",
    },
  },
  {
    "bindings": {
      "ctrl-alt-right": "workspace::ActivatePaneRight",
    },
  },
  {
    "context": "!Editor",
    "bindings": {
      "ctrl-alt-shift-up": "vim::ResizePaneUp",
    },
  },
  {
    "context": "!Editor",
    "bindings": {
      "ctrl-alt-shift-right": "vim::ResizePaneLeft",
    },
  },
  {
    "context": "!Editor",
    "bindings": {
      "ctrl-alt-shift-down": "vim::ResizePaneDown",
    },
  },
  {
    "context": "!Editor",
    "bindings": {
      "ctrl-alt-shift-left": "vim::ResizePaneRight",
    },
  },
  {
    "context": "GitPanel",
    "bindings": {
      "ctrl-z": "git::Uncommit",
      "ctrl-delete": "git::RestoreTrackedFiles",
      "ctrl-s": "git::Fetch",
    },
  },
]
