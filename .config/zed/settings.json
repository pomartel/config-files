// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "restore_on_startup": "last_workspace",
  "theme": "Omazed",
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "gpt-5.4",
    },
  },

  "agent_servers": {
    "codex": {
      "favorite_config_option_values": {
        "model": ["gpt-5.4"],
      },
      "default_config_options": {
        "mode": "full-access",
      },
    },
  },
  "auto_indent_on_paste": true,
  "auto_install_extensions": {
    "astro": true,
    "basher": true,
    "colored-zed-icons-theme": true,
    "html": true,
    "lua": true,
    "ruby": true,
    "scss": true,
    "toml": true,
    "vscode-great-icons": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "base_keymap": "VSCode",
  "buffer_font_family": "JetBrainsMonoNL Nerd Font Mono",
  "buffer_font_size": 15,
  "ensure_final_newline_on_save": false,
  "file_types": {
    "markdown": ["*.marp"],
    "Shell Script": ["", ".env.*"],
  },
  "format_on_save": "on",
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "icon_theme": "Colored Zed Icons Theme Dark",
  "languages": {
    "Shell Script": {
      "ensure_final_newline_on_save": true,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "arguments": ["--filename", "{buffer_path}", "--indent", "2"],
          // Change `--indent 2` to match your preferred tab_size
          "command": "shfmt",
        },
      },
      "tab_size": 2,
    },
  },
  "minimap": {
    "show": "never",
  },
  "preferred_line_length": 100,
  "preview_tabs": {
    "enabled": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "soft_wrap": "editor_width",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "copy_on_select": true,
  },
  "ui_font_size": 16,
}
